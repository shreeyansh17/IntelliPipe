# ──────────────────────────────────────────────────────────────────────────────
# IntelliPipe Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=IntelliPipe
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
TENANT_ID=default

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intellipipe
DB_USER=intellipipe
DB_PASSWORD=intellipipe
DB_POOL_SIZE=20
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_RAW_EVENTS_TOPIC=raw_events
KAFKA_DLQ_TOPIC=dead_letter_queue
KAFKA_CONSUMER_GROUP_ID=intellipipe-consumers
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_APP_NAME=IntelliPipe-Streaming
SPARK_MASTER=local[*]
SPARK_CHECKPOINT_LOCATION=/tmp/intellipipe/checkpoints
SPARK_TRIGGER_INTERVAL=30 seconds
SPARK_WATERMARK_DELAY=10 minutes
SPARK_SHUFFLE_PARTITIONS=8
SPARK_MAX_OFFSETS_PER_TRIGGER=10000

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=intellipipe-anomaly-detection

# ── LLM / Claude API ─────────────────────────────────────────────────────────
LLM_ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_CLAUDE_MODEL=claude-opus-4-5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3
LLM_RATE_LIMIT_RPM=60

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_ORG=intellipipe-org
GITHUB_REPO=data-platform
GITHUB_BASE_BRANCH=main
GITHUB_PR_REVIEWERS=data-eng-lead,platform-oncall
GITHUB_REQUIRE_APPROVAL=true

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://intellipipe.atlassian.net
JIRA_EMAIL=data-platform@intellipipe.io
JIRA_API_TOKEN=REPLACE_ME
JIRA_PROJECT_KEY=DQAI

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_INCIDENT_CHANNEL=#data-incidents
SLACK_LOW_SEVERITY_CHANNEL=#data-quality-alerts

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=intellipipe-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_PROMETHEUS_PORT=8000
OTEL_LOG_LEVEL=INFO
OTEL_ENABLE_TRACING=true
OTEL_ENABLE_METRICS=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_SECRET_KEY=GENERATE_WITH_openssl_rand_-hex_32
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_RATE_LIMIT_REQUESTS=1000

# ── Anomaly Detection ─────────────────────────────────────────────────────────
ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.05
ANOMALY_ISOLATION_FOREST_N_ESTIMATORS=100
ANOMALY_AUTOENCODER_LATENT_DIM=16
ANOMALY_AUTOENCODER_EPOCHS=50
ANOMALY_ZSCORE_THRESHOLD=3.5
ANOMALY_ENSEMBLE_WEIGHTS_IF=0.4
ANOMALY_ENSEMBLE_WEIGHTS_AE=0.4
ANOMALY_ENSEMBLE_WEIGHTS_ZSCORE=0.2

# ── Data Quality ──────────────────────────────────────────────────────────────
DQ_FRESHNESS_SLA_MINUTES=30
DQ_NULL_SPIKE_THRESHOLD_PCT=0.05
DQ_DUPLICATE_THRESHOLD_PCT=0.01
DQ_SCHEMA_DRIFT_ALERT_THRESHOLD=1
